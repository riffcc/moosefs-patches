diff --git a/mfsdata/mfschunkserver.cfg b/mfsdata/mfschunkserver.cfg
index 5555555..6666666 100644
--- a/mfsdata/mfschunkserver.cfg
+++ b/mfsdata/mfschunkserver.cfg
@@
 # enables/disables sparsification (skip zeros) during write
 # HDD_SPARSIFY_ON_WRITE = 1
+
+# experimental extended patch:
+# allow a special CLTOCS_WRITE protocol flag that permits CSTOCL_WRITE_STATUS
+# replies for fragment writeids to be emitted out of order on middle chunkservers.
+# this is intended for pipelined userspace writers that maintain their own
+# completion scoreboard and only finalize after all writeids are acknowledged.
+# do not enable unless every writer in the path understands out-of-order
+# fragment acknowledgements.
+# ENABLE_OOO_WRITE_ACKS = 0
