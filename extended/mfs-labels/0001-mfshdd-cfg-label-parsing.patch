From 6f6ea66851a5c9db310a9679cc7cc25edef87f8c Mon Sep 17 00:00:00 2001
From: Benjamin Arntzen <zorlin@gmail.com>
Date: Wed, 4 Mar 2026 21:59:50 +0000
Subject: [PATCH] mfschunkserver: parse optional disk labels in mfshdd entries

---
 mfschunkserver/hddspacemgr.c | 144 +++++++++++++++++++++++++++++++++++
 1 file changed, 144 insertions(+)

diff --git a/mfschunkserver/hddspacemgr.c b/mfschunkserver/hddspacemgr.c
index a35a1fe..aaa475e 100644
--- a/mfschunkserver/hddspacemgr.c
+++ b/mfschunkserver/hddspacemgr.c
@@ -277,6 +277,8 @@ typedef struct hddstats {
 
 typedef struct folder {
 	char *path;
+	uint32_t disklabelmask;
+	uint8_t hasdisklabelmask;
 #define SCST_WORKING 0
 #define SCST_SCANNEEDED 1
 #define SCST_ATTRNEEDED 2
@@ -8380,6 +8382,105 @@ int hdd_size_parse_u64(const char *str,uint64_t *ret) {
 	return 1;
 }
 
+static inline uint8_t hdd_islabelschar(char c,char expected) {
+	return (c==expected || c==(expected-'a'+'A'))?1:0;
+}
+
+static int hdd_parse_label_mask(const char *labelsstr,uint32_t *labelmask) {
+	const char *p;
+	char c;
+	uint32_t mask,newlabelmask;
+	uint8_t sep,perr;
+
+	newlabelmask = 0;
+	perr = 0;
+	sep = 0;
+	for (p=labelsstr ; *p ; p++) {
+		c = *p;
+		if (c>='A' && c<='Z') {
+			mask = (1U<<(c-'A'));
+		} else if (c>='a' && c<='z') {
+			mask = (1U<<(c-'a'));
+		} else {
+			mask = 0;
+		}
+		if (mask) {
+			if (sep) {
+				mfs_log(MFSLOG_SYSLOG_STDERR,MFSLOG_WARNING,"hdd space manager: labels parser - separator not found before label %c",c);
+				perr = 1;
+			} else {
+				sep = 1;
+			}
+			if (newlabelmask & mask) {
+				mfs_log(MFSLOG_SYSLOG_STDERR,MFSLOG_WARNING,"hdd space manager: labels parser - found duplicate label %c",c);
+				perr = 1;
+			}
+			newlabelmask |= mask;
+		} else if (c==',' || c==';') {
+			if (sep) {
+				sep = 0;
+			} else {
+				if (newlabelmask!=0) {
+					mfs_log(MFSLOG_SYSLOG_STDERR,MFSLOG_WARNING,"hdd space manager: labels parser - more than one separator found");
+				} else {
+					mfs_log(MFSLOG_SYSLOG_STDERR,MFSLOG_WARNING,"hdd space manager: labels parser - found separator at the beginning of definition");
+				}
+				perr = 1;
+			}
+		} else if (c!=' ' && c!='\t') {
+			mfs_log(MFSLOG_SYSLOG_STDERR,MFSLOG_WARNING,"hdd space manager: labels parser - unrecognized character %c",c);
+			perr = 1;
+		}
+	}
+	if (sep==0 && newlabelmask!=0) {
+		mfs_log(MFSLOG_SYSLOG_STDERR,MFSLOG_WARNING,"hdd space manager: labels parser - found separator at the end of definition");
+		perr = 1;
+	}
+	if (perr) {
+		return -1;
+	}
+	*labelmask = newlabelmask;
+	return 0;
+}
+
+// returns 0 when "labels=..." option was parsed, 1 when option is not present, -1 on parse error
+static int hdd_parse_labels_suffix(char *suffix,uint32_t *labelmask) {
+	char *p,*e,*labelsstart;
+
+	p = suffix;
+	while (*p==' ' || *p=='\t') {
+		p++;
+	}
+	if (*p=='\0') {
+		return 1;
+	}
+	if (p[0]=='\0' || p[1]=='\0' || p[2]=='\0' || p[3]=='\0' || p[4]=='\0' || p[5]=='\0' || !hdd_islabelschar(p[0],'l') || !hdd_islabelschar(p[1],'a') || !hdd_islabelschar(p[2],'b') || !hdd_islabelschar(p[3],'e') || !hdd_islabelschar(p[4],'l') || !hdd_islabelschar(p[5],'s')) {
+		return 1;
+	}
+	p += 6;
+	while (*p==' ' || *p=='\t') {
+		p++;
+	}
+	if (*p!='=') {
+		mfs_log(MFSLOG_SYSLOG_STDERR,MFSLOG_WARNING,"hdd space manager: labels parser - missing '=' in labels option");
+		return -1;
+	}
+	p++;
+	while (*p==' ' || *p=='\t') {
+		p++;
+	}
+	labelsstart = p;
+	e = labelsstart + strlen(labelsstart);
+	while (e>labelsstart && (e[-1]==' ' || e[-1]=='\t')) {
+		e--;
+	}
+	*e = '\0';
+	if (hdd_parse_label_mask(labelsstart,labelmask)<0) {
+		return -1;
+	}
+	return 0;
+}
+
 int hdd_parseline(char *hddcfgline) {
 	uint32_t l,p;
 	int lfd,mfr,bm,is;
@@ -8395,6 +8496,8 @@ int hdd_parseline(char *hddcfgline) {
 	uint8_t lmode;
 	double ldata;
 	uint8_t pmode;
+	uint32_t disklabelmask;
+	uint8_t hasdisklabels;
 	uint64_t mainmetaid,metaid;
 
 	if (hddcfgline[0]=='#') {
@@ -8408,6 +8511,40 @@ int hdd_parseline(char *hddcfgline) {
 		return 0;
 	}
 	hddcfgline[l]='\0';
+
+	disklabelmask = 0;
+	hasdisklabels = 0;
+	if (hddcfgline[l-1]==']') {
+		uint32_t lb,el;
+		int lret;
+		lb = l-1;
+		while (lb>0 && hddcfgline[lb]!='[') {
+			lb--;
+		}
+		if (hddcfgline[lb]=='[') {
+			el = l-1;
+			hddcfgline[el] = '\0';
+			lret = hdd_parse_labels_suffix(hddcfgline+lb+1,&disklabelmask);
+			hddcfgline[el] = ']';
+			if (lret<0) {
+				mfs_log(MFSLOG_SYSLOG_STDERR,MFSLOG_WARNING,"hdd space manager: labels parse error in line: %s",hddcfgline);
+				return -1;
+			}
+			if (lret==0) {
+				hasdisklabels = 1;
+				l = lb;
+				while (l>0 && (hddcfgline[l-1]==' ' || hddcfgline[l-1]=='\t')) {
+					l--;
+				}
+				if (l==0) {
+					mfs_log(MFSLOG_SYSLOG_STDERR,MFSLOG_WARNING,"hdd space manager: missing path in line with labels definition");
+					return -1;
+				}
+				hddcfgline[l] = '\0';
+			}
+		}
+	}
+
 	p = l;
 	while (p>0 && hddcfgline[p-1]!=' ' && hddcfgline[p-1]!='\t') {
 		p--;
@@ -8754,9 +8891,14 @@ int hdd_parseline(char *hddcfgline) {
 					// the change is important - chunks need to be send to master again
 					f->sendneeded = 1;
 				}
+				if (f->disklabelmask!=disklabelmask || f->hasdisklabelmask!=hasdisklabels) {
+					f->sendneeded = 1;
+				}
 			}
 			f->lmode = lmode;
 			f->ldata = ldata;
+			f->disklabelmask = disklabelmask;
+			f->hasdisklabelmask = hasdisklabels;
 			f->markforremoval = mfr;
 			f->balancemode = bm;
 			f->ignoresize = is;
@@ -8782,6 +8924,8 @@ int hdd_parseline(char *hddcfgline) {
 	f->toremove = REMOVING_NO;
 	f->lmode = lmode;
 	f->ldata = ldata;
+	f->disklabelmask = disklabelmask;
+	f->hasdisklabelmask = hasdisklabels;
 	f->avail = 0ULL;
 	f->total = 0ULL;
 	f->lastblocks = 0;
-- 
